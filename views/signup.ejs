<% const activePage = 'signup'; %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign Up - ProjectAnalyzer</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>

  <%- include('partials/navbar', { activePage }) %>

  <main class="auth-main">
    <div class="auth-wrapper reveal-on-scroll">
      <div class="mascot-card auth-mascot" aria-hidden="true">
        <div class="mascot-avatar"></div>
        <div class="speech-bubble">New developer detected.</div>
      </div>
      <div class="auth-header">
        <span class="eyebrow">Operator Registry</span>
        <h1>Create Operator Profile</h1>
        <p>Prepare your account for repo scans and score archives.</p>
      </div>

      <div class="card auth-card">
        <form id="signup-form" novalidate action="/signup" method="POST">
          <div class="form-group">
            <label class="form-label" for="signup-name">Full Name</label>
            <input type="text" id="signup-name" name="name" class="input-control" placeholder="John Doe" required>
            <span class="input-error-msg" id="signup-name-error">Please enter your name.</span>
          </div>

          <div class="form-group">
            <label class="form-label" for="signup-email">Email Address</label>
            <input type="email" id="signup-email" name="email" class="input-control" placeholder="name@example.com" required>
            <span class="input-error-msg" id="signup-email-error">Please enter a valid email address.</span>
          </div>

          <div class="form-group">
            <label class="form-label" for="signup-password">Password</label>
            <input type="password" id="signup-password" name="password" class="input-control" placeholder="At least 8 characters" required>
            <span class="input-error-msg" id="signup-password-error">Password must be at least 8 characters.</span>
          </div>

          <div class="form-group">
            <label class="form-label" for="signup-confirm-password">Confirm Password</label>
            <input type="password" id="signup-confirm-password" name="confirmPassword" class="input-control" placeholder="Re-enter password" required>
            <span class="input-error-msg" id="signup-confirm-password-error">Passwords do not match.</span>
          </div>

          <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 0.5rem;" id="signup-btn">
            Create Account
          </button>
        </form>
      </div>

      <div class="auth-footer">
        <p>Already have an account? <a href="/login" id="link-to-login">Log in here</a></p>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script src="/js/main.js"></script>
</body>
</html>
