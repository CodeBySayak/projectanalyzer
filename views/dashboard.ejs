<% const activePage = 'dashboard'; %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - ProjectAnalyzer</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>

  <%- include('partials/navbar', { activePage }) %>

  <main>
    <div class="dashboard-container">
      <div class="dashboard-header">
        <h1>Evaluate GitHub Repository</h1>
        <p>Enter a public repository URL and select parameters to generate an in-depth score report.</p>
      </div>

      <form id="analyzer-form" novalidate action="/result" method="GET">
        <!-- URL Input -->
        <div class="form-group">
          <label class="form-label" for="repo-url">Repository URL</label>
          <div class="url-input-container">
            <input type="url" id="repo-url" name="url" class="input-control" placeholder="https://github.com/facebook/react" required>
          </div>
          <span class="input-error-msg" id="url-error" style="text-align: left; display: block; margin-top: -1.5rem; margin-bottom: 1.5rem; display: none;">
            Please enter a valid GitHub repository URL (e.g., https://github.com/owner/repo).
          </span>
        </div>

        <!-- Parameter Selection Header -->
        <div class="param-section-title">
          <h2>Evaluation Parameters</h2>
          <button type="button" class="param-toggle-all" id="toggle-all-btn">Select All</button>
        </div>

        <!-- Checkbox Parameter Grid -->
        <div class="param-grid">
          <label class="param-card selected" for="param-doc">
            <input type="checkbox" id="param-doc" name="params" value="Documentation" checked>
            <span>Documentation</span>
          </label>

          <label class="param-card selected" for="param-commits">
            <input type="checkbox" id="param-commits" name="params" value="Commits per Contributor" checked>
            <span>Commits per Contributor</span>
          </label>

          <label class="param-card selected" for="param-contributors">
            <input type="checkbox" id="param-contributors" name="params" value="Total Contributors" checked>
            <span>Total Contributors</span>
          </label>

          <label class="param-card selected" for="param-stars">
            <input type="checkbox" id="param-stars" name="params" value="Stars" checked>
            <span>Stars</span>
          </label>

          <label class="param-card selected" for="param-forks">
            <input type="checkbox" id="param-forks" name="params" value="Forks" checked>
            <span>Forks</span>
          </label>

          <label class="param-card selected" for="param-prs">
            <input type="checkbox" id="param-prs" name="params" value="Pull Requests" checked>
            <span>Pull Requests</span>
          </label>

          <label class="param-card selected" for="param-structure">
            <input type="checkbox" id="param-structure" name="params" value="Folder Structure" checked>
            <span>Folder Structure</span>
          </label>

          <label class="param-card selected" for="param-readme">
            <input type="checkbox" id="param-readme" name="params" value="README Quality" checked>
            <span>README Quality</span>
          </label>

          <label class="param-card selected" for="param-responsiveness">
            <input type="checkbox" id="param-responsiveness" name="params" value="Responsiveness" checked>
            <span>Responsiveness</span>
          </label>

          <label class="param-card selected" for="param-org">
            <input type="checkbox" id="param-org" name="params" value="Code Organization" checked>
            <span>Code Organization</span>
          </label>
        </div>
        <span class="input-error-msg" id="param-error" style="text-align: left; display: block; margin-top: -1.5rem; margin-bottom: 2rem; display: none;">
          Please select at least one evaluation parameter.
        </span>

        <!-- Submit Button -->
        <button type="submit" class="btn btn-primary btn-large" style="padding: 0.9rem 2.5rem; font-size: 1.05rem;" id="analyze-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 0.25rem;">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          Analyze Repository
        </button>
      </form>
    </div>

    <!-- Frontend-only Loading Spinner Overlay -->
    <div class="loader-overlay" id="loading-overlay">
      <div class="spinner-container">
        <div class="spinner-ring"></div>
        <svg class="spinner-brand-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
        </svg>
      </div>
      <div class="loader-message-holder" id="loader-status">Connecting to GitHub...</div>
      <div class="loader-sub-msg">Analyzing code quality and metrics</div>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script src="/js/main.js"></script>
</body>
</html>
