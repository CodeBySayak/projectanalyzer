<%
  // Determine if nav links should be shown (e.g., hide on login/signup pages)
  const isAuthPage = locals.activePage === 'login' || locals.activePage === 'signup';
  const showNav = !isAuthPage;
%>
<div class="ambient-hud" aria-hidden="true">
  <div class="hud-widget hud-widget-left"><span>SYSTEM</span><strong>ONLINE</strong></div>
  <div class="hud-widget hud-widget-right"><span>AI CORE</span><strong>READY</strong></div>
</div>

<nav class="navbar">
  <div class="navbar-container">
    <a href="<%= showNav ? '/dashboard' : '#' %>" class="navbar-brand">
      <svg class="brand-logo-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
      </svg>
      <span>ProjectAnalyzer</span>
      <small>Repository Intelligence System</small>
    </a>

    <% if (showNav) { %>
      <button class="navbar-toggle" id="navbar-toggle-btn" aria-label="Toggle navigation">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>

      <div class="navbar-menu" id="navbar-menu-list">
        <a href="/dashboard" class="navbar-link <%= locals.activePage === 'dashboard' ? 'active' : '' %>" id="nav-link-dashboard">Dashboard</a>
        <a href="/history" class="navbar-link <%= locals.activePage === 'history' ? 'active' : '' %>" id="nav-link-history">History</a>
        <span class="system-pill">System Online</span>
        <button class="navbar-logout" id="navbar-logout-btn">Logout</button>
      </div>
    <% } %>
  </div>
</nav>
