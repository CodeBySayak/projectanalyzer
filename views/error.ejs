<%
  const activePage = 'dashboard';
  
  // Detect error type from locals or default to a generic error
  const errorType = locals.errorType || "invalid_url";
  
  let errorTitle = "An Error Occurred";
  let errorMessage = "Something went wrong while evaluating the repository. Please try again.";
  
  if (errorType === "invalid_url") {
    errorTitle = "Invalid GitHub URL";
    errorMessage = "The URL you entered does not match a valid GitHub repository format. Please check the format and try again (e.g., https://github.com/facebook/react).";
  } else if (errorType === "not_found") {
    errorTitle = "Repository Not Found";
    errorMessage = "The repository could not be found on GitHub. Make sure the repository exists, is public, and the owner and name are spelled correctly.";
  } else if (errorType === "rate_limit") {
    errorTitle = "API Limit Exceeded";
    errorMessage = "GitHub API rate limit has been exceeded for your request. Please wait a few minutes and try again.";
  } else if (errorType === "network_error") {
    errorTitle = "Network Connection Error";
    errorMessage = "A network timeout or disconnect occurred. Please verify your internet connection and try again.";
  }
%>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= errorTitle %> - ProjectAnalyzer</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>

  <%- include('partials/navbar', { activePage }) %>

  <main>
    <div class="error-wrapper reveal-on-scroll">
      <span class="eyebrow">System Error</span>
      <div class="error-svg-container" id="error-illustration-holder">
        <!-- We will render the matching SVG based on the errorType -->
        <% if (errorType === "invalid_url") { %>
          <!-- Invalid URL: Broken Link / Warning Triangle -->
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width: 100%; height: 100%;">
            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
            <line x1="12" y1="9" x2="12" y2="13"></line>
            <line x1="12" y1="17" x2="12.01" y2="17"></line>
          </svg>
        <% } else if (errorType === "not_found") { %>
          <!-- Not Found: Question Mark / Search Folders -->
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width: 100%; height: 100%;">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
            <line x1="12" y1="17" x2="12.01" y2="17"></line>
          </svg>
        <% } else if (errorType === "rate_limit") { %>
          <!-- Rate Limit: Hourglass / Clock -->
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width: 100%; height: 100%;">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
        <% } else { %>
          <!-- Network Error: Wifi Off -->
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width: 100%; height: 100%;">
            <line x1="1" y1="1" x2="23" y2="23"></line>
            <path d="M16.72 11.06A10.94 10.94 0 0 1 19 12.5"></path>
            <path d="M5 12.5a10.94 10.94 0 0 1 5.83-2.84"></path>
            <path d="M7.42 15a14.85 14.85 0 0 1 3-1.85"></path>
            <path d="M14 13.2a14.85 14.85 0 0 1 2.58 1.8"></path>
            <path d="M9.83 17.5a19.24 19.24 0 0 1 4.34 0"></path>
          </svg>
        <% } %>
      </div>

      <h1 id="error-title-text">Mission Failed: <%= errorTitle %></h1>
      <p id="error-description-text"><%= errorMessage %></p>

      <a href="/dashboard" class="btn btn-primary" id="error-back-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 0.25rem;">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Go Back
      </a>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script src="/js/main.js"></script>
</body>
</html>
